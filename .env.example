# Site — use your real domain (e.g. https://www.buyselleric.com). If this is still
# https://…vercel.app, OG / iMessage previews will ignore it and use buyselleric.com
# or VERCEL_PROJECT_PRODUCTION_URL when enabled in Vercel project settings.
NEXT_PUBLIC_SITE_URL=https://buyselleric.com

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: never commit or expose in client code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin panel (/admin) — pick a strong password and a long random secret
ADMIN_PASSWORD=change-me-to-something-strong
ADMIN_SESSION_SECRET=use-a-long-random-string-at-least-32-chars

# OpenAI — powers AI blog generation in the admin panel
OPENAI_API_KEY=sk-...

# GAMLS RETS MLS feed — powers MLS listing sync
RETS_LOGIN_URL=https://gamls-rets.connectmls.com/server/login
RETS_USERNAME=YOUR_RETS_USERNAME_IN_ALL_CAPS
RETS_PASSWORD=your_rets_password
CRON_SECRET=a-long-random-secret-for-cron-auth

# Bridge Interactive (Bridge Data Output) — RESO Web API live IDX feed.
# When BOTH Bridge and Spark are configured, /listings merges results from both.
# BRIDGE_SERVER_TOKEN=
# BRIDGE_DATASET_ID=
# Optional: BRIDGE_ODATA_BASE, BRIDGE_ODATA_ENTITY (default Property)

# Spark Platform (Flexmls / FBS) — RESO Web API v3 live feed.
# Provided in Spark’s API access email. Access Token is the only credential
# needed for authenticated requests; the API Feed ID is informational and
# only useful when contacting api-support@sparkplatform.com.
# Docs: https://sparkplatform.com/docs/reso/overview
# SPARK_ACCESS_TOKEN=
# SPARK_API_FEED_ID=
# Optional overrides:
# SPARK_ODATA_BASE=https://replication.sparkapi.com/Version/3/Reso/OData
# SPARK_PROPERTY_ENTITY=Property
# SPARK_MEDIA_ENTITY=Media
# SPARK_ODATA_MAX_TOP=200

# Multi-feed merge: max rows pulled per upstream feed when both Bridge and
# Spark are enabled. Default 1500. Per-feed pages are fetched in parallel so
# higher caps stay responsive (~1-3s extra at 4000 rows/feed). Lift only if
# users routinely page past the cap and the truncation hint is showing.
# MULTI_FEED_MERGE_MAX_ROWS=1500
# MAP_PINS_MAX_ROWS_PER_FEED=1500

# MLS sync: skip per-listing RETS photo calls when RETS reports more than this many
# matches (keeps /api/mls/sync within serverless time limits). Use admin “Fetch photos”
# to backfill. Default 800. Set higher (e.g. 5000) only on long-running jobs.
MLS_SYNC_PHOTO_MAX_TOTAL=800

# MLS /api/mls/sync: each POST processes one page (default 400 rows). Admin “Sync now” chains requests.
# Photo backfill: run supabase/mls-listings-missing-photos-rpc.sql so /api/admin/mls/photos can page
# efficiently by listing id.
# Optional: listings per cron tick for /api/cron/mls-photo-backfill (default 22).
# MLS_PHOTO_CRON_BATCH_SIZE=22
